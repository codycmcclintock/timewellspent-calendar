// Copy to your Xcode project as Secrets.xcconfig (or merge into Debug/Release xcconfigs).
// Add Secrets.xcconfig to .gitignore — do NOT commit real keys.
//
// These values are safe to embed in the iOS binary (public Supabase anon key + URLs).
// NEVER add SUPABASE_SERVICE_ROLE_KEY, ANTHROPIC_API_KEY, or OPENAI_API_KEY here.

SUPABASE_URL = https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_JWT

// Production web app URL — used for invite links and universal links
APP_URL = https://YOUR-VERCEL-DOMAIN

// Optional — only if using Google Maps SDK in the native app
// MAPS_API_KEY = YOUR_GOOGLE_MAPS_API_KEY
